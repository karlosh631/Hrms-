# =====================================================
#  HRMS Auto Attendance Bot – Environment Variables
# =====================================================
# Copy this file to .env and fill in your values.
# DO NOT commit the real .env to version control.

# ── REQUIRED ──────────────────────────────────────
# Your Horilla HRMS login credentials
HRMS_USERNAME=your_username_here
HRMS_PASSWORD=your_password_here

# HRMS site URL (default is below)
HRMS_URL=https://hrms.technimus.com/

# ── SCHEDULE (optional, edit to change times) ─────
# 8 AM permission popup
PERMISSION_HOUR=8
PERMISSION_MINUTE=0

# 10:00 AM clock-in
CLOCKIN_HOUR=10
CLOCKIN_MINUTE=0

# 5:05 PM clock-out
CLOCKOUT_HOUR=17
CLOCKOUT_MINUTE=5

# ── RETRY SETTINGS ────────────────────────────────
# Maximum number of retry attempts per task
MAX_RETRIES=20
# Seconds between retries when offline
RETRY_INTERVAL=300

# ── MODES ─────────────────────────────────────────
# Set to true to run without a GUI (Linux server, cloud, Docker)
HRMS_CLOUD_MODE=false

# Set to true to automatically grant permission daily (no popup)
HRMS_AUTO_APPROVE=false

# Set to true to hide the Chromium browser window during automation
HRMS_HEADLESS=true

# Port for the cloud web dashboard (http://your-server:8080)
CLOUD_API_PORT=8080

# ── TELEGRAM (optional cloud permission) ──────────
# Get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
